NODE_ENV=production

POSTGRES_USER=attendance
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
POSTGRES_DB=attendance
DATABASE_URL=postgresql://attendance:replace-with-a-long-random-database-password@postgres:5432/attendance?schema=public

DASHBOARD_BIND=127.0.0.1:3000
DEVICE_GATEWAY_BIND=127.0.0.1:4001
POSTGRES_BIND=127.0.0.1:5432
WORKER_POLL_INTERVAL_SECONDS=60

SESSION_SECRET=replace-with-at-least-32-random-bytes
PASSWORD_PEPPER=replace-with-at-least-32-random-bytes
DEVICE_SIGNATURE_MAX_AGE_SECONDS=300

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=attendance@example.com
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM="Attendance System <attendance@example.com>"
