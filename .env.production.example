NODE_ENV=production

# PostgreSQL container configuration; Compose derives container DATABASE_URL values
POSTGRES_USER=attendance
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
POSTGRES_DB=attendance

# Host port bindings used by Docker Compose
DASHBOARD_BIND=127.0.0.1:3000
DEVICE_GATEWAY_BIND=127.0.0.1:4001
POSTGRES_BIND=127.0.0.1:5432

# Dashboard
SESSION_SECRET=replace-with-at-least-32-random-bytes

# Device gateway
DEVICE_SIGNATURE_MAX_AGE_SECONDS=300
