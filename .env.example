NODE_ENV=development

POSTGRES_USER=attendance
POSTGRES_PASSWORD=attendance_dev_password
POSTGRES_DB=attendance
DATABASE_URL=postgresql://attendance:attendance_dev_password@localhost:5432/attendance?schema=public

DASHBOARD_BIND=127.0.0.1:3000
DEVICE_GATEWAY_BIND=127.0.0.1:4001
POSTGRES_BIND=127.0.0.1:5432
WORKER_POLL_INTERVAL_SECONDS=60

SESSION_SECRET=dev-only-session-secret-change-for-shared-envs
PASSWORD_PEPPER=dev-only-password-pepper-change-for-shared-envs
DEVICE_SIGNATURE_MAX_AGE_SECONDS=300
DEV_DEVICE_SECRET=dev-device-secret

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Attendance System <attendance@example.com>"
