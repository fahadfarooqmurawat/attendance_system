generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum DeviceStatus {
  ACTIVE
  DISABLED
  OFFLINE
}

enum DeviceMode {
  SCAN
  ENROLL
}

enum EnrollmentSessionStatus {
  PENDING
  CLAIMED
  SUCCEEDED
  FAILED
  CANCELLED
  EXPIRED
}

enum FingerprintEnrollmentStatus {
  ACTIVE
  REVOKED
}

enum ManualAttendanceRequestType {
  ADD_SCAN
  REMOVE_SCAN
}

enum ManualAttendanceRequestStatus {
  PENDING_MANAGER
  PENDING_HR
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

enum ApproverKind {
  MANAGER
  HR
  OWNER
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum NotificationType {
  APPROVAL_REQUESTED
  APPROVAL_REMINDER
  ATTENDANCE_ANOMALY
  DEVICE_OFFLINE
  ENROLLMENT_FAILED
  REPORT_READY
}

enum ReportExportStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model Employee {
  id                   String                    @id @default(cuid())
  email                String                    @unique
  employeeCode         String?                   @unique
  fullName             String
  passwordHash         String
  status               EmployeeStatus            @default(ACTIVE)
  managerId            String?
  roleId               String?
  timezone             String                    @default("Asia/Karachi")
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  role                 Role?                     @relation(fields: [roleId], references: [id], onDelete: SetNull)
  manager              Employee?                 @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports        Employee[]                @relation("EmployeeManager")
  approvalSteps        ApprovalStep[]            @relation("ApprovalStepApprover")
  auditLogs            AuditLog[]                @relation("AuditLogActor")
  fingerprintRecords   FingerprintEnrollment[]
  requestedEnrollments EnrollmentSession[]       @relation("EnrollmentRequestedBy")
  enrollmentSessions   EnrollmentSession[]
  manualRequests       ManualAttendanceRequest[] @relation("ManualRequestEmployee")
  createdRequests      ManualAttendanceRequest[] @relation("ManualRequestCreatedBy")
  notifications        Notification[]
  reportExports        ReportExport[]
  scanEvents           ScanEvent[]
  shiftAssignments     EmployeeShiftAssignment[]

  @@index([managerId])
}

model Device {
  id                     String                  @id @default(cuid())
  name                   String
  location               String?
  apiKeyHash             String
  status                 DeviceStatus            @default(ACTIVE)
  reportedMode           DeviceMode              @default(SCAN)
  modeChangedAt          DateTime                @default(now())
  firmwareVersion        String?
  lastSeenAt             DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  enrollmentSessions     EnrollmentSession[]
  fingerprintEnrollments FingerprintEnrollment[]
  scanEvents             ScanEvent[]

  @@index([status, lastSeenAt])
}

model FingerprintEnrollment {
  id                String                      @id @default(cuid())
  employeeId        String
  deviceId          String
  scannerTemplateId Int
  status            FingerprintEnrollmentStatus @default(ACTIVE)
  enrolledAt        DateTime                    @default(now())
  revokedAt         DateTime?
  device            Device                      @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  employee          Employee                    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([deviceId, scannerTemplateId])
  @@unique([employeeId, deviceId])
}

model EnrollmentSession {
  id                    String                  @id @default(cuid())
  employeeId            String
  deviceId              String
  requestedByEmployeeId String
  scannerTemplateId     Int?
  status                EnrollmentSessionStatus @default(PENDING)
  errorMessage          String?
  expiresAt             DateTime
  claimedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  device                Device                  @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  employee              Employee                @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  requestedBy           Employee                @relation("EnrollmentRequestedBy", fields: [requestedByEmployeeId], references: [id])

  @@index([deviceId, status, expiresAt])
  @@index([employeeId, status])
}

model ScanEvent {
  id                 String                    @id @default(cuid())
  deviceId           String
  employeeId         String?
  scannerTemplateId  Int
  deviceScanSequence Int?
  firmwareVersion    String?
  matchConfidence    Decimal?                  @db.Decimal(5, 4)
  rawPayload         Json?
  serverReceivedAt   DateTime                  @default(now())
  createdAt          DateTime                  @default(now())
  removedByRequests  ManualAttendanceRequest[] @relation("RemovedScan")
  device             Device                    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  employee           Employee?                 @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@unique([deviceId, deviceScanSequence])
  @@index([employeeId, serverReceivedAt])
  @@index([deviceId, serverReceivedAt])
}

model Shift {
  id           String                    @id @default(cuid())
  name         String
  timezone     String                    @default("Asia/Karachi")
  startTime    String
  endTime      String
  workdays     Int[]
  graceMinutes Int                       @default(0)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  assignments  EmployeeShiftAssignment[]
}

model EmployeeShiftAssignment {
  id            String    @id @default(cuid())
  employeeId    String
  shiftId       String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift         Shift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([employeeId, effectiveFrom, effectiveTo])
}

model ManualAttendanceRequest {
  id                  String                        @id @default(cuid())
  employeeId          String
  createdByEmployeeId String
  type                ManualAttendanceRequestType
  requestedTimestamp  DateTime?
  targetScanEventId   String?
  reason              String
  status              ManualAttendanceRequestStatus @default(PENDING_MANAGER)
  appliedAt           DateTime?
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt
  approvalSteps       ApprovalStep[]
  createdBy           Employee                      @relation("ManualRequestCreatedBy", fields: [createdByEmployeeId], references: [id])
  employee            Employee                      @relation("ManualRequestEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  targetScanEvent     ScanEvent?                    @relation("RemovedScan", fields: [targetScanEventId], references: [id], onDelete: SetNull)

  @@index([employeeId, createdAt])
  @@index([status, createdAt])
}

model ApprovalStep {
  id                        String                  @id @default(cuid())
  manualAttendanceRequestId String
  sequence                  Int
  approverEmployeeId        String
  approverKind              ApproverKind
  status                    ApprovalStatus          @default(PENDING)
  comment                   String?
  decidedAt                 DateTime?
  createdAt                 DateTime                @default(now())
  approver                  Employee                @relation("ApprovalStepApprover", fields: [approverEmployeeId], references: [id], onDelete: Cascade)
  manualAttendanceRequest   ManualAttendanceRequest @relation(fields: [manualAttendanceRequestId], references: [id], onDelete: Cascade)

  @@unique([manualAttendanceRequestId, sequence])
  @@index([approverEmployeeId, status])
}

model Notification {
  id         String             @id @default(cuid())
  employeeId String
  type       NotificationType
  status     NotificationStatus @default(UNREAD)
  title      String
  body       String
  payload    Json?
  readAt     DateTime?
  createdAt  DateTime           @default(now())
  employee   Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, status, createdAt])
}

model AuditLog {
  id         String    @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  createdAt  DateTime  @default(now())
  actor      Employee? @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
}

model JobRun {
  id         String    @id @default(cuid())
  jobName    String
  status     String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  details    Json?

  @@index([jobName, startedAt])
}

model ReportExport {
  id            String             @id @default(cuid())
  requestedById String
  name          String
  status        ReportExportStatus @default(PENDING)
  parameters    Json
  filePath      String?
  errorMessage  String?
  createdAt     DateTime           @default(now())
  completedAt   DateTime?
  requestedBy   Employee           @relation(fields: [requestedById], references: [id], onDelete: Cascade)

  @@index([requestedById, createdAt])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  permissions RolePermission[]
  employees   Employee[]
}

model Permission {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}
