{
  "name": "attendance-system",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @attendance/db generate",
    "db:migrate": "pnpm --filter @attendance/db migrate:dev",
    "db:migrate:deploy": "pnpm --filter @attendance/db migrate:deploy",
    "db:seed": "pnpm --filter @attendance/db seed",
    "db:studio": "pnpm --filter @attendance/db studio",
    "dev": "turbo run dev --parallel",
    "dev:dashboard": "pnpm --filter @attendance/dashboard dev",
    "dev:device-gateway": "pnpm --filter @attendance/device-gateway dev",
    "dev:worker": "pnpm --filter @attendance/worker dev",
    "docker:down": "docker compose down",
    "docker:up": "docker compose up --build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "postinstall": "pnpm --filter @attendance/db generate",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.10",
    "eslint": "^9.30.1",
    "prettier": "^3.6.2",
    "turbo": "^2.5.4",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.36.0"
  }
}
