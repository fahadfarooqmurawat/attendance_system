{
  "name": "attendance-system",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "db:clear": "pnpm --filter @attendance/db clear",
    "db:generate": "pnpm --filter @attendance/db generate",
    "db:migrate": "pnpm --filter @attendance/db migrate:dev",
    "db:migrate:deploy": "pnpm --filter @attendance/db migrate:deploy",
    "db:seed": "pnpm --filter @attendance/db seed",
    "db:studio": "pnpm --filter @attendance/db studio",
    "dev": "turbo run dev --parallel",
    "dev:dashboard": "pnpm --filter @attendance/dashboard dev",
    "dev:device-gateway": "pnpm --filter @attendance/device-gateway dev",
    "dev:worker": "pnpm --filter @attendance/worker dev",
    "docker:db:up": "docker compose up -d postgres",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:prod:config": "docker compose --env-file .env.production -f docker-compose.yml -f docker-compose.prod.yml config",
    "docker:up": "docker compose up -d --build",
    "firmware:build": "pio run -d apps/firmware",
    "firmware:clean": "pio run -d apps/firmware -t clean",
    "firmware:intellisense": "pio run -d apps/firmware -t compiledb",
    "firmware:monitor": "pio device monitor -d apps/firmware",
    "firmware:test": "pio test -d apps/firmware -e native",
    "firmware:test:device": "pio test -d apps/firmware -e esp32dev",
    "firmware:upload": "pio run -d apps/firmware -t upload",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "postinstall": "pnpm --filter @attendance/db generate",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
